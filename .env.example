# Postgres connection string (Supabase-compatible)
# Use the pooler URI from Supabase → Project Settings → Database (often aws-1-<region>.pooler.supabase.com:6543)
DATABASE_URL=postgresql://postgres.PROJECT_REF:password@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# HTTP server port for tRPC + SSE
PORT=3001

# Randomized live-feed emitter interval (milliseconds)
EMITTER_MIN_INTERVAL_MS=4000
EMITTER_MAX_INTERVAL_MS=8000

# Solana Pay (devnet)
SOLANA_DEVNET_RPC=https://api.devnet.solana.com

# Runtime demo fallback — set to true to skip devnet and use mock signatures
# Flip live during a demo if devnet is slow: MOCK_PAY=true
MOCK_PAY=false

# Optional: base58-encoded secret key for scripts/verify-day3-devnet.ts only
# DEVNET_PAYER_SECRET=
# Or place a Solana CLI keypair at scripts/.devnet-payer.json (gitignored)

# verify-day3-devnet.ts options (defaults shown)
# DEVNET_TRY_AIRDROP=false
# DEVNET_BOOTSTRAP_USDC=true   # mint a devnet-only test token when Circle USDC is unavailable
# DEVNET_USDC_MINT=            # override USDC mint (set automatically when bootstrapping)
